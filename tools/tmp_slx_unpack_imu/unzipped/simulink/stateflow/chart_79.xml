        <P Name="isEML">1</P>
        <P Name="script">function F_eq = F_eq_from_ref(v_ref, theta_ref, m, g, c_r, rho, CdA)
%#codegen
% v_ref, theta_ref: 输入端口
% m,g,c_r,rho,CdA  : 本块的 Parameter（标量 double）
v = max(v_ref, 0);
F_roll = c_r * m * g * cos(theta_ref);
F_aero = 0.5 * rho * CdA .* (v.^2);
F_eq = F_roll + F_aero;

% 保持“前馈不含 m·g·sinθ”，以免与 MD 通道重复补偿。</P>
      </eml>
