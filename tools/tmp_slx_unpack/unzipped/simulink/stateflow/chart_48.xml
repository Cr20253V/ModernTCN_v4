        <P Name="isEML">1</P>
        <P Name="script">% 误差计算模块
function y_e = Global2PathError(X, Y, psi, v, omega, ref_vec)
% ref_vec = [X_ref; Y_ref; psi_ref; kappa_ref; v_ref]
% 输出: y_e = [e_y; e_psi; e_v; e_omega; e_s]

%#codegen
% 1) 解包参考
Xr = ref_vec(1);
Yr = ref_vec(2);
psir = ref_vec(3);
kappa = ref_vec(4);
v_ref = ref_vec(5);

% 2) 横向误差：沿参考法向量投影（带符号）
ex = X - Xr; 
ey = Y - Yr;
e_y = -sin(psir)*ex + cos(psir)*ey;

% 3) 航向、速度、角速度误差
e_psi   = wrapToPi(psi - psir);
e_v     = v - v_ref;
omega_ff= v_ref * kappa;           % 曲率前馈
e_omega = omega - omega_ff;

% 4) 进度误差（可选，如未使用可置 0）
e_s = 0;

y_e = [e_y; e_psi; e_v; e_omega];
end
</P>
      </eml>
    </state>
