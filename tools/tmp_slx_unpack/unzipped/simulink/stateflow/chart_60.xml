        <P Name="script">function [plant, y_wt, u_wt, du_wt, ecr_wt, umin, umax] = UpdatePlantModel(rho, db_rt, MPC_idx, ff_rt, v_ff_nom)
%#codegen

% 标称权重/约束
Q0  = [16.3225, 29.0359, 6.9898, 2.7642];
% Q0  = [3, 8, 1, 1];
R0  = [1e-3, 1e-3];
dR0 = [1e-2, 1e-2];
umin0 = [-300; -0.6];
umax0 = [ 300;  0.6];

% 纯数值 maps：启用 ρ→(Q/R/dR/umin/umax)
maps_local = struct();
maps_local.enable_weight_interp = true;
maps_local.Q_range  = [0.5*Q0; 1.5*Q0];
maps_local.R_range  = [0.5*R0; 1.5*R0];
maps_local.dR_range = [0.5*dR0; 1.5*dR0];
% 约束：随 |ω| 插值（行1→行2）
maps_local.umin_range = [ (1.20*umin0).&apos;; (1.00*umin0).&apos; ];
maps_local.umax_range = [ (1.00*umax0).&apos;; (1.20*umax0).&apos; ];

% 在线插值
upd = mpc_update_from_rho(rho, db_rt, maps_local);

% 组装 3 输入（2 MV + 1 MD）
A   = upd.A; Bmv = upd.B; C = upd.C; Dmv = upd.D;
nx  = size(A,1); ny = size(C,1); nd = 1;
if isfield(upd,&apos;E&apos;) &amp;&amp; ~isempty(upd.E), Bmd = upd.E(:,1); else, Bmd = zeros(nx,1); end
Dmd = zeros(ny,nd);

plant.A = A;
plant.B = [Bmv, Bmd];   % 4x3
plant.C = C;
plant.D = [Dmv, Dmd];   % 4x3

% 名义 U（仅滚阻+风阻；坡度由 MD 处理）
% theta = rho(3);
% F_rolling = ff_rt.c_r * ff_rt.m * ff_rt.g * cos(theta);
% F_aero    = 0.5 * ff_rt.rho * ff_rt.CdA * v_ff_nom^2;
% F_eq      = F_rolling + F_aero;
% plant.U  = [F_eq; 0; 0];
plant.U  = [0; 0; 0];

% 其它名义量与采样时间（严格按总序）
plant.X  = zeros(nx,1);
plant.Y  = zeros(ny,1);
plant.DX = zeros(nx,1);
plant.Ts = db_rt.Ts;

% 外部权重/约束端口（列向量）
if isfield(upd,&apos;Q&apos;) &amp;&amp; ~isempty(upd.Q),  y_wt  = upd.Q(:);  else, y_wt  = Q0(:);  end
if isfield(upd,&apos;R&apos;) &amp;&amp; ~isempty(upd.R),  u_wt  = upd.R(:);  else, u_wt  = R0(:);  end
if isfield(upd,&apos;dR&apos;)&amp;&amp; ~isempty(upd.dR), du_wt = upd.dR(:); else, du_wt = dR0(:); end
ecr_wt = 1e4;  % 若需随ρ调度，可按 upd.rho_n 构造插值

if isfield(upd,&apos;umin&apos;) &amp;&amp; ~isempty(upd.umin), umin = upd.umin(:); else, umin = umin0; end
if isfield(upd,&apos;umax&apos;) &amp;&amp; ~isempty(upd.umax), umax = upd.umax(:); else, umax = umax0; end
end</P>
