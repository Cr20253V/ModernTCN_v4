%#codegen
% gru_vec = [label_main; label_turn; conf_main]

gv = [1; 0; 1]; % 默认: flat / straight / high confidence
if ~isempty(gru_vec)
g = double(gru_vec(:));
n = min(3, numel(g));
gv(1:n) = g(1:n);
end

[plant, y_wt, u_wt, du_wt, ecr_wt, umin, umax] = UpdatePlantModel_gru( ...
rho, db_rt, MPC_idx, ff_rt, v_ff_nom, gv);
