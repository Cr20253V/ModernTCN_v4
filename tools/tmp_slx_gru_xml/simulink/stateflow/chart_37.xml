      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [rho_f, rho_n] = RhoFilter(v_in, omega_in, theta_in, Ts, tau)
% 一阶离散滤波
persistent v_f_prev w_f_prev t_f_prev
if isempty(v_f_prev), v_f_prev = 0; end
if isempty(w_f_prev), w_f_prev = 0; end
if isempty(t_f_prev), t_f_prev = 0; end

a = Ts / max(tau + Ts, 1e-6);

v_f = (1 - a)*v_f_prev + a*max(v_in, 0);   % 速度不取负·
w_f = (1 - a)*w_f_prev + a*omega_in;       % 保留符号
t_f = (1 - a)*t_f_prev + a*theta_in;       % 保留符号

v_f_prev = v_f; w_f_prev = w_f; t_f_prev = t_f;

rho_f = [v_f; w_f; t_f];

% 可选归一化（仅用于监控/调试，不参与UpdatePlantModel）
Vmax = 2.0; Wmax = 0.8; Tmax = deg2rad(10);
rho_n = [min(v_f/Vmax,1); min(abs(w_f)/Wmax,1); min(abs(t_f)/Tmax,1)];
end</P>
      </eml>
    </state>
